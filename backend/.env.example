# AI HealthTrack Environment Variables
# Copy this file to .env and update values

# Application
APP_NAME=AI HealthTrack
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./healthtrack.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost/healthtrack

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI/ML Settings
WHISPER_MODEL=base
# OPENAI_API_KEY=your-openai-key  # Optional: for enhanced AI

# Language Settings
DEFAULT_LANGUAGE=en
# Supported: en, hi, ta, te

# TTS Settings
TTS_ENGINE=groq

# Groq AI Settings (for TTS/STT/LLM)
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# Optional: external medicine DB JSON generated via Kaggle import script
# Defaults to backend/app/knowledge/generated_medicine_db.json if unset
MEDICINE_DB_JSON_PATH=

# Medication Reminder Settings
MEDICATION_FEATURE_ENABLED=true
REMINDER_SNOOZE_MINUTES=15
DEFAULT_REMINDER_ADVANCE_MINUTES=5
CAREGIVER_NOTIFY_AFTER_MINUTES=60

# Prescription Scanner Performance
RX_SCANNER_FAST_MODE=true
RX_SCANNER_MAX_AI_LOOKUPS=1
RX_SCANNER_LLM_TIMEOUT_SECONDS=6

# Twilio Settings (for SMS/WhatsApp/Voice reminders)
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890
# TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

